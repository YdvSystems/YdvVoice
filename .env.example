# .env.example — variables d'environnement YdvVoice (Sophia)
# Copier en `.env` (gitignored, JAMAIS committé) et remplir les valeurs.
# Repo PUBLIC : ce fichier ne contient QUE des noms — aucune valeur réelle.
# Liste complétée au fil de la Phase 3 — voir docs/VISION.md § Variables d'environnement.

# --- Auth Claude — sous abonnement Max, sans clé API facturée (voir A1) ---
# Token OAuth (~1 an) généré par `claude setup-token`. SECRET — jamais committé.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Voix (TTS ElevenLabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Wake word (Picovoice Porcupine) ---
PICOVOICE_ACCESS_KEY=

# --- Identité / wording (NON secrets) ---
ASSISTANT_NAME=Sophia
WAKE_WORD=dis-moi-sophia

# --- Collecteurs proactifs (Phase 3) ---
# Chemins vers des fichiers de credentials Google (les fichiers eux-mêmes = gitignored)
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_GMAIL_CREDENTIALS=

# --- Socle process (plan 00, T0) ---
# Racine des données (base, snapshots, audit). Dev = dossier JETABLE ; prod = G:\Sophia (plan 05).
SOPHIA_HOME=
# Port du sidecar en DEV. En prod, attribué dynamiquement au spawn (T3).
SIDECAR_PORT=8770
