    "test:u-t0-gitleaks": "node tests/u-t0-gitleaks.mjs",
    "test:u-t1": "node tests/u-t1.mjs",
    "test:u-t2": "node tests/u-t2.mjs",
    "test:u-t3": "node tests/u-t3.mjs",
    "test:u-t4": "node tests/u-t4.mjs",
    "test:u-t5": "node tests/u-t5.mjs",
    "test:i-t5": "node tests/i-t5.mjs",
    "test:u-t6": "node tests/u-t6.mjs",
    "test:u-warm": "node tests/u-warm.mjs",
    "test:u-states": "node tests/u-states.mjs",
    "test:u-router": "node tests/u-router.mjs",
    "test:u-portier-parity": "node tests/u-portier-parity.mjs",
    "test:u-metrics": "node tests/u-metrics.mjs",
