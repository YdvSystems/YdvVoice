    "e2e:v1": "npm run build && node tests/e2e/e2e-v1.mjs",
    "e2e:v2": "npm run build && node tests/e2e/e2e-v2.mjs",
    "e2e:v3": "npm run build && node tests/e2e/e2e-v3.mjs",
    "e2e:v4": "npm run build && node tests/e2e/e2e-v4.mjs",
    "e2e:v5": "npm run build && node tests/e2e/e2e-v5.mjs",
    "e2e:v6": "npm run build && node tests/e2e/e2e-v6.mjs",
    "e2e:v7": "npm run build && node tests/e2e/e2e-v7.mjs",
    "e2e:v8": "npm run build && node tests/e2e/e2e-v8.mjs",
    "e2e:v9": "npm run build && node tests/e2e/e2e-v9.mjs",
